generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Penerimaan {
  id                Int       @id @default(autoincrement())
  namaMuzakki       String    @map("nama_muzakki") @db.VarChar(100)
  nomorHp           String?   @map("nomor_hp") @db.VarChar(20)
  kategoriId        String    @map("kategori_id") @db.VarChar(50)
  jumlahUang        Decimal?  @default(0) @map("jumlah_uang") @db.Decimal(12, 2)
  jumlahBeras       Decimal?  @default(0) @map("jumlah_beras") @db.Decimal(5, 2)
  metodePembayaran  String?   @default("Tunai") @map("metode_pembayaran") @db.VarChar(30)
  tanggalPenerimaan DateTime? @default(now()) @map("tanggal_penerimaan") @db.Timestamp(6)
  keterangan        String?   @map("keterangan")

  @@map("penerimaan")
}

model Penyaluran {
  id                Int       @id @default(autoincrement())
  namaMustahik      String    @map("nama_mustahik") @db.VarChar(100)
  kategoriId        String    @map("kategori_id") @db.VarChar(50)
  jumlahUang        Decimal?  @default(0) @map("jumlah_uang") @db.Decimal(12, 2)
  jumlahBeras       Decimal?  @default(0) @map("jumlah_beras") @db.Decimal(5, 2)
  tanggalPenyaluran DateTime? @default(now()) @map("tanggal_penyaluran") @db.Timestamp(6)
  keterangan        String?   @map("keterangan")

  @@map("penyaluran")
}

model KategoriZIS {
  id        Int     @id @default(autoincrement())
  nama      String  @unique @map("nama_kategori") @db.VarChar(50)
  deskripsi String? @map("deskripsi")

  @@map("kategori_zis")
}

model UserAmil {
  id        Int      @id @default(autoincrement())
  nama      String   @map("nama") @db.VarChar(100)
  username  String   @unique @map("username") @db.VarChar(50)
  password  String   @map("password") @db.VarChar(100)
  role      String   @default("Amil") @map("role") @db.VarChar(20) // Admin, Bendahara, Amil
  status    String   @default("Aktif") @map("status") @db.VarChar(20) // Aktif, Nonaktif
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("user_amil")
}
